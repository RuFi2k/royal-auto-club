# ── docker-compose variables ───────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose up

# PostgreSQL password for the crm_app user
DB_PASSWORD=

# Full URL of the deployed client (used for CORS)
CORS_ORIGIN=https://your-app.vercel.app

# Firebase project ID (Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID=

# AES-256-GCM encryption key — 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
