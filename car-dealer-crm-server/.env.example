# Path to pg_dump binary — Windows only; leave unset in Docker (pg_dump is on PATH)
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe

# PostgreSQL connection string
# Append ?connection_limit=20&pool_timeout=15 for production
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/car_dealer_crm"

PORT=3000

# Restrict to your frontend origin in production
CORS_ORIGIN=http://localhost:5173

# Firebase project ID — used to verify ID tokens (no service account needed)
FIREBASE_PROJECT_ID=

# Path to Firebase Admin service account JSON (download from Firebase Console →
# Project Settings → Service Accounts → Generate new private key)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# AES-256-GCM key for encrypting sensitive DB fields (64-char hex = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
